{
    "name": "paw-ofelas",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "vitest run --project unit",
        "test:watch": "vitest --project unit",
        "e2e": "playwright test",
