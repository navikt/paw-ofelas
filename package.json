        "test-storybook": "vitest --project storybook --run",
        "prepare": "husky"
    },
    "dependencies": {
        "@navikt/aksel-icons": "8.10.5",
        "@navikt/arbeidssokerregisteret-utils": "2.1.0",
        "@navikt/ds-css": "8.10.5",
        "@navikt/ds-react": "8.10.5",
        "@navikt/nav-dekoratoren-moduler": "4.1.1",
        "next": "16.2.6",
        "react": "19.2.6",
        "react-dom": "19.2.6"
    },
    "devDependencies": {
        "@axe-core/playwright": "4.11.3",
        "@playwright/test": "1.60.0",
        "@storybook/addon-a11y": "10.4.0",
        "@storybook/addon-docs": "10.4.0",
        "@storybook/addon-vitest": "10.4.0",
        "@storybook/nextjs-vite": "10.4.0",
        "@tailwindcss/postcss": "4.3.0",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@types/node": "25.6.2",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitest/browser-playwright": "4.1.5",
        "@vitest/coverage-v8": "4.1.5",
        "eslint": "9.39.4",
        "eslint-config-next": "16.2.6",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-storybook": "10.4.0",
        "husky": "9.1.7",
        "lint-staged": "16.4.0",
        "playwright": "1.60.0",
        "prettier": "3.8.3",
        "storybook": "10.4.0",
        "tailwindcss": "4.3.0",
        "typescript": "5.9.3",
        "vite": "8.0.12",
        "vitest": "4.1.5"
    },
    "engines": {
        "node": "24.16.0"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,json,md}": [
